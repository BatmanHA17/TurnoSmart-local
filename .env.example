# TurnoSmart — Variables de entorno
# Copia este archivo como .env (desarrollo local) o .env.local (apuntar a producción)
# NUNCA commitees .env o .env.local con valores reales

# ─── Supabase ───────────────────────────────────────────────────────────────

# URL del proyecto Supabase (local o cloud)
# Local:      http://localhost:54321
# Producción: https://TU_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=http://localhost:54321

# Anon/public key del proyecto (no es secreta, va en el frontend)
# Local:      Ver output de `supabase start`
# Producción: Dashboard → Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui

# ─── Sentry — Error monitoring (opcional, solo producción) ──────────────────
# Obtén el DSN en: sentry.io → Tu proyecto → Settings → Client Keys (DSN)
# Si no está definido, Sentry no se activa (no rompe nada)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── Opcional (solo si usas características específicas) ────────────────────

# URL de la app para redirecciones OAuth y magic links
# VITE_APP_URL=http://localhost:8080
